@model IEnumerable<MyAccount.Models.Customer>
@using PagedList
@using PagedList.Mvc
@{
    ViewBag.Title = "客户信息列表";
}

<h2>客户信息列表</h2>
@using (Html.BeginForm("Index","Customers",FormMethod.Get))
{
    @Html.DropDownList("findBy", ViewBag.findByItems as List<SelectListItem>)
    @Html.TextBox("keyword")
    <input type="submit" value="搜索" />
}
<p>
    @Html.ActionLink("新建客户信息", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.Id)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Num)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Name)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Balance)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.LastTime)
        </th>
        <th>
            @Html.Label("操作")
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.Id)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Num)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Name)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Balance)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.LastTime)
        </td>
        <td>
            @Html.ActionLink("编辑", "Edit", new { id=item.Id }, new { target = "_blank" }) |
            @Html.ActionLink("详情", "Details", new { id=item.Id }, new { target = "_blank" }) |
            @Html.ActionLink("删除", "Delete", new { id=item.Id }, new { target = "_blank" })
        </td>
    </tr>
}

</table>
@Html.PagedListPager((IPagedList)Model, page => Url.Action("Index", new { page, findBy = ViewBag.findBy, keyword = ViewBag.keyword }))