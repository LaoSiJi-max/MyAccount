@model IEnumerable<MyAccount.Models.Customer>
@using PagedList
@using PagedList.Mvc
@{
    ViewBag.Title = "客户余额信息表";
    List<SelectListItem> findByItems = ViewBag.findByItems as List<SelectListItem>;
}

<h2>客户余额信息表</h2>
@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.DropDownList("findBy", findByItems)
    @Html.TextBox("keyword")
    <input type="submit" value="搜索"/>
}
@Html.ActionLink("将此结果导出到Excel","ToExcel",new { findBy = ViewBag.findBy, keyword = ViewBag.keyword },new {target="_blank" })
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.Id)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Num)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Name)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Balance)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.LastTime)
        </th>
        <th>
            操作
        </th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Num)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Balance)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LastTime)
            </td>
            <td>
                @Html.ActionLink("记账", "BalanceChange", new { id = item.Id }, new { target = "_blank" }) | 
                @Html.ActionLink("交易记录", "AccLogList", new { id=item.Id }, new { target = "_blank" })
            </td>
        </tr>
    }

</table>
@Html.PagedListPager((IPagedList)Model, page => Url.Action("Index", new { page, findBy = ViewBag.findBy, keyword = ViewBag.keyword }))